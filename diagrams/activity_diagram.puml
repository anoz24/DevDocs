@startuml
skinparam handwritten false
skinparam class {
    BackgroundColor White
    ArrowColor DarkBlue
    BorderColor DarkBlue
}
skinparam Partition {
    BorderColor Gray
    BackgroundColor LightGray
}
title "DevDocs" Activity Diagram
|User|
start
:Access DevDocs;
:App Initialization;
partition "Navigation Flow" {
|App|
:Fetch/Load Markdown Content from API;
:Display Side Navigation (Nested Categories);
|User|
repeat
  :View Side Navigation;
  :Select a Topic (Nested Route);
  |App|
  :Update URL Path;
  :Swap Main Content area (Child Router Outlet);
  :Render Markdown as Styled HTML;
  if (Content contains sections?) then (yes)
    :Populate Right TOC (On-page navigation);
  endif
  :Display Center Main Content;
|User|
repeat while ()
-> [search];
}
partition "Search Flow (RxJS)" {
|User|
:Type in Global Search Input;
|App|
:Start debounceTime timer (RxJS);
if (User stops typing for > debounceTime?) then (yes)
  :Apply filtering to Side Navigation Tree;
  :Update Side Navigation view (Real-time);
else (no)
  :Reset debounceTime timer;
  stop
endif
|User|
}
partition "Interactions" {
|User|
fork
  :Click 'Copy Code' Button;
  |App|
  :Execute Copy Code Component;
  :Copy selected code block to clipboard;
fork again
  :Click 'Favorite' (Bookmark) icon;
  |App|
  if (Is topic already favorited?) then (yes)
    :Remove topic from Favorites;
    :Delete favorite from localStorage;
  else (no)
    :Add topic to Favorites;
    :Save favorite to localStorage;
  endif
|User|
end fork
}
:Exit App;
|User|
stop
@enduml