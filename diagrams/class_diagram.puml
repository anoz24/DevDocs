@startuml
' --- Configuration for Clarity ---
left to right direction
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam ArrowFontSize 11
skinparam ArrowFontColor #555555
skinparam ArrowMessageAlignment center
hide circle

package "Components" #F9F9F9 {
    class ShellComponent <<Component>> {
      +isMobileMenuOpen: boolean
      -routerSub: Subscription
      +ngOnInit()
      +ngOnDestroy()
      +toggleMobileMenu()
      +closeMobileMenu()
    }
    class SidebarComponent <<Component>> {
      +filteredSections$: Observable
      +expandedSections: Set
      +ngOnInit()
      +toggleExpand(id)
      +isExpanded(id)
      +navigateTo(section)
      -filterTree(sections, term)
    }
    class DocViewerComponent <<Component>> {
      +currentSection: DocSection
      -destroy$: Subject
      +ngOnInit()
      +onMarkdownReady()
      +ngOnDestroy()
    }
    class SearchBarComponent <<Component>> {
      +searchControl: FormControl
      -destroy$: Subject
      +ngOnInit()
      +ngOnDestroy()
    }
    class TocComponent <<Component>> {
      +scrollTo(id)
    }
    class FavoritesComponent <<Component>> {
      +navigateTo(id)
    }
}

package "Services" #EEF4FB {
    class DocsStateService {
      -loaded: boolean
      +sections$: Observable
      +loadReadme()
      +getSectionById(id)
      -findSection(sections, id)
    }
    class GithubService {
      -base: string
      -owner: string
      -repo: string
      -token: string
      +getReadme(): Observable<string>
    }
    class DocsParserService {
      +parse(markdown): DocSection[]
      +slugify(text): string
    }
    class FavoritesService {
      -KEY: string
      -favorites: BehaviorSubject<Favorite[]>
      +getAll(): Observable
      +isFavorite(id): boolean
      +toggle(section)
      -load(): Favorite[]
    }
    class TocService {
      +toc$: Observable
      +buildFromDOM()
      +clear()
    }
    class SidebarFilterService {
      +currentTerm$: Observable
      -term$: BehaviorSubject<>
      +setTerm(term)
    }
    class ThemeService {
      +isDark: Signal
      +toggle()
      +init()
    }
    class CopyCodeService {
      +attachButtons()
    }
}

package "Models" #FFFBE6 {
    interface DocSection {
      +id: string
      +title: string
      +level: number
      +content: string
      +children: DocSection[]
    }
    interface Favorite {
      +id: string
      +title: string
      +savedAt: number
    }
}

' --- COMPLETE RELATIONSHIPS ---
' Component Dependencies (Injection)
ShellComponent ..> DocsStateService : injects
ShellComponent ..> ThemeService : injects
SidebarComponent ..> DocsStateService : injects
SidebarComponent ..> SidebarFilterService : injects
DocViewerComponent ..> DocsStateService : injects
DocViewerComponent ..> FavoritesService : injects
DocViewerComponent ..> CopyCodeService : injects
DocViewerComponent ..> TocService : injects
SearchBarComponent ..> SidebarFilterService : injects
TocComponent ..> TocService : injects
FavoritesComponent ..> FavoritesService : injects

' Service to Service
DocsStateService -right-> GithubService : fetches raw data
DocsStateService -right-> DocsParserService : parses MD to JSON

' Structural Containment
ShellComponent *-down- SidebarComponent
ShellComponent *-down- TocComponent
SidebarComponent *-down- SearchBarComponent

' Data usage
DocsStateService ..> DocSection : populates
FavoritesService ..> Favorite : manages
SidebarComponent ..> DocSection : displays
@enduml